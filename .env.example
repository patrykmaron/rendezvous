# Copy to .env at the repo root and fill in values, then symlink into the
# workspaces that load env from their own directory:
#   ln -s ../../.env apps/web/.env
#   ln -s ../../.env packages/tasks/.env

# Managed Postgres — PgBouncer (port 6432) for app runtime
DATABASE_URL=
# Managed Postgres — direct (port 5432) for drizzle-kit migrations
DATABASE_URL_DIRECT=

# ClickHouse Cloud (HTTPS endpoint, port 8443)
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rendezvous
