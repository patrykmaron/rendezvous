# Copy to .env at the repo root and fill in values, then symlink into the
# workspaces that load env from their own directory:
#   ln -s ../../.env apps/web/.env
#   ln -s ../../.env packages/tasks/.env

# Managed Postgres — PgBouncer (port 6432) for app runtime
DATABASE_URL=
# Managed Postgres — direct (port 5432) for drizzle-kit migrations
DATABASE_URL_DIRECT=

# ClickHouse Cloud (HTTPS endpoint, port 8443)
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rendezvous

# TfL Unified API (https://api-portal.tfl.gov.uk) — app_key auth.
# Secondary key is used once as a fallback when the primary gets a 429
# (TfL returns 429 for both invalid keys and rate limiting).
TFL_PRIMARY_KEY=
TFL_SECONDARY_KEY=

# Mapbox public pk. token, exposed to the browser by Next.js.
NEXT_PUBLIC_MAPBOX_TOKEN=

LIVEBLOCKS_PUB_KEY=
LIVEBLOCKS_SECRET_KEY=

# Trigger.dev dev API key from Trigger.dev dashboard → Project → API keys;
# deployed runs configure env in the dashboard instead.
TRIGGER_SECRET_KEY=

# OpenAI API key; the SDK default env var is OPENAI_API_KEY so code passes
# this explicitly.
OPENAI_KEY=

# Google Places API (New) — server-side only (Text Search + Place Photos); previews degrade gracefully when unset
GOOGLE_PLACES_KEY=